function sumAndMultiply(n: number): number {
    let x = 0;
    let sum = 0;
    let place = 1;

    while (n > 0) {
        let digit = n % 10;
        
        if (digit !== 0) {
            // Reconstruct x from right to left in its original positional order
            x = digit * place + x;
            sum += digit;
            place *= 10;
        }
        
        n = Math.floor(n / 10);
    }

    return x * sum;
}